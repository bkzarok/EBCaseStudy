@model EBCaseStudy.Models.Api.PaginatedProductResponse

@{
    ViewData["Title"] = "Products";
}

<h1>Products</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="category" class="form-control" placeholder="Filter by category" value="@ViewBag.Category" />
                <div class="input-group-append">
                    <button type="submit" class="btn btn-primary">Filter</button>
                </div>
            </div>
        </form>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortBy="Name" asp-route-category="@ViewBag.Category">Name</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortBy="Category" asp-route-category="@ViewBag.Category">Category</a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Category)
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Product pagination">
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" asp-action="Index"
               asp-route-pageNumber="@(Model.PageNumber - 1)"
               asp-route-pageSize="@Model.PageSize"
               asp-route-category="@ViewBag.Category"
               asp-route-sortBy="@ViewBag.SortBy"
               tabindex="-1" aria-label="Previous">
                <span aria-hidden="true">&laquo;</span>
            </a>
        </li>
        @{
            int totalPages = (Model.TotalCount + Model.PageSize - 1) / Model.PageSize;
            int startPage = Math.Max(1, Model.PageNumber - 2);
            int endPage = Math.Min(totalPages, Model.PageNumber + 2);

            if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="1"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-category="@ViewBag.Category"
                       asp-route-sortBy="@ViewBag.SortBy">1</a>
                </li>
                if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-category="@ViewBag.Category"
                       asp-route-sortBy="@ViewBag.SortBy">@i</a>
                </li>
            }

            if (endPage < totalPages)
            {
                if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@totalPages"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-category="@ViewBag.Category"
                       asp-route-sortBy="@ViewBag.SortBy">@totalPages</a>
                </li>
            }
        }
        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" asp-action="Index"
               asp-route-pageNumber="@(Model.PageNumber + 1)"
               asp-route-pageSize="@Model.PageSize"
               asp-route-category="@ViewBag.Category"
               asp-route-sortBy="@ViewBag.SortBy"
               aria-label="Next">
                <span aria-hidden="true">&raquo;</span>
            </a>
        </li>
    </ul>
</nav>

