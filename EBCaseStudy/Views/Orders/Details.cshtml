@model EBCaseStudy.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<h1>Order Details</h1>

<div>
    <h4>Order #@Model.Id</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UserName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UserName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.OrderDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.OrderDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>
</div>

<h5>Order Items</h5>
<table class="table">
    <thead>
        <tr>
            <th>Product Name</th>
            <th>Quantity</th>
            <th>Price at Time of Order</th>
            <th>Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OrderItems)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Quantity</td>
                <td>@item.PriceAtTimeOfOrder.ToString("C")</td>
                <td>@((item.Quantity * item.PriceAtTimeOfOrder).ToString("C"))</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <h5>Actions</h5>
    @if (Model.Status == EBCaseStudy.Models.OrderStatus.New)
    {
        <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-inline">
            <button type="submit" name="status" value="Approved" class="btn btn-success">Approve</button>
        </form>
        <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-inline">
            <button type="submit" name="status" value="Rejected" class="btn btn-danger">Reject</button>
        </form>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit Quantities</a>
    }

    @if (Model.Status == EBCaseStudy.Models.OrderStatus.Approved)
    {
        <form asp-action="Reorder" asp-route-id="@Model.Id" method="post" class="d-inline">
            <button type="submit" class="btn btn-info">Reorder</button>
        </form>
    }
</div>


<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>
